{
  "manifest_version": 3,
  "name": "Gold Digger",
  "version": "1.2.0",
  "description": "Sync Discogs marketplace prices into the Gold Digger cart optimizer",
  "permissions": ["storage", "cookies", "tabs", "windows"],
  "host_permissions": [
    "https://stream.ronautradio.la/*",
    "https://www.discogs.com/*",
    "http://localhost:*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://stream.ronautradio.la/*",
        "http://localhost:*/*"
      ],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Gold Digger"
  },
  "background": {
    "service_worker": "background.js"
  }
}
