{
  "manifest_version": 3,
  "name": "Gold Digger",
  "version": "1.2.0",
  "description": "Sync Discogs marketplace prices into the Gold Digger cart optimizer",
  "permissions": ["storage", "cookies", "tabs", "windows"],
  "host_permissions": [
    "https://stream.ronautradio.la/*",
    "https://www.discogs.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://stream.ronautradio.la/*"
      ],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Gold Digger",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
